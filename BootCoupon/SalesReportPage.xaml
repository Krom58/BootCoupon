            <TextBlock Grid.Column="8" Text="จำนวนทั้งหมด" FontWeight="SemiBold" Padding="5" HorizontalAlignment="Center" TextAlignment="Center"/>
            <TextBlock Grid.Column="9" Text="ราคาคูปองฟรี" FontWeight="SemiBold" Padding="5" HorizontalAlignment="Center" TextAlignment="Center"/>
            <TextBlock Grid.Column="10" Text="ราคาที่จ่าย" FontWeight="SemiBold" Padding="5" HorizontalAlignment="Center" TextAlignment="Center"/>
            <TextBlock Grid.Column="11" Text="มูลค่ารวม" FontWeight="SemiBold" Padding="5" HorizontalAlignment="Center" TextAlignment="Center"/>
            <TextBlock Grid.Column="12" Text="เหตุผลยกเลิก" FontWeight="SemiBold" Padding="5" HorizontalAlignment="Center" TextAlignment="Center" Foreground="Red"/>

            <!-- vertical separators -->
            <Rectangle Grid.Column="0" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
            <Rectangle Grid.Column="1" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
            <Rectangle Grid.Column="2" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
            <Rectangle Grid.Column="3" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
            <Rectangle Grid.Column="4" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
            <Rectangle Grid.Column="5" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
            <Rectangle Grid.Column="6" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
            <Rectangle Grid.Column="7" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
            <Rectangle Grid.Column="8" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
            <Rectangle Grid.Column="9" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
            <Rectangle Grid.Column="10" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
            <Rectangle Grid.Column="11" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
        </Grid>
    </Grid>
</Border>

                        <!-- CancelledReceipts items - เพิ่มเหตุผลยกเลิก -->
                        <ItemsControl Grid.Row="1" ItemsSource="{x:Bind ViewModel.ReportData, Mode=OneWay}" 
              Visibility="{Binding Path=ViewModel.ReportMode, ElementName=RootPage, Converter={StaticResource ReportModeToVisibility}, ConverterParameter=CancelledReceipts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="local:SalesReportItem">
                                    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="10,8">
                                        <Grid MinWidth="1900">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="1*" MinWidth="90"/>
                                                <ColumnDefinition Width="1.2*" MinWidth="100"/>
                                                <ColumnDefinition Width="2*" MinWidth="150"/>
                                                <ColumnDefinition Width="1.2*" MinWidth="100"/>
                                                <ColumnDefinition Width="1.2*" MinWidth="100"/>
                                                <ColumnDefinition Width="1.2*" MinWidth="100"/>
                                                <ColumnDefinition Width="0.9*" MinWidth="85"/>
                                                <ColumnDefinition Width="0.9*" MinWidth="85"/>
                                                <ColumnDefinition Width="0.9*" MinWidth="85"/>
                                                <ColumnDefinition Width="1*" MinWidth="90"/>
                                                <ColumnDefinition Width="1*" MinWidth="90"/>
                                                <ColumnDefinition Width="1.2*" MinWidth="100"/>
                                                <ColumnDefinition Width="2.5*" MinWidth="200"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Grid.Column="0" Text="{x:Bind ReceiptDateDisplay}" VerticalAlignment="Center" Padding="5" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind ReceiptCode}" VerticalAlignment="Center" Padding="5" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{x:Bind CustomerName}" VerticalAlignment="Center" TextWrapping="Wrap" Padding="5" TextTrimming="CharacterEllipsis" MaxLines="2" HorizontalAlignment="Center" TextAlignment="Left"/>
                                            <TextBlock Grid.Column="3" Text="{x:Bind CustomerPhone}" VerticalAlignment="Center" Padding="5" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="4" Text="{x:Bind SalesPersonName}" VerticalAlignment="Center" TextWrapping="Wrap" Padding="5" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="5" Text="{x:Bind PaymentMethodName}" VerticalAlignment="Center" TextWrapping="Wrap" Padding="5" HorizontalAlignment="Center" TextAlignment="Center"/>
                                            <TextBlock Grid.Column="6" Text="{x:Bind PaidCouponCount}" VerticalAlignment="Center" Padding="5" HorizontalAlignment="Center" TextAlignment="Center" Foreground="Green" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="7" Text="{x:Bind FreeCouponCount}" VerticalAlignment="Center" Padding="5" HorizontalAlignment="Center" TextAlignment="Center" Foreground="Orange" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="8" Text="{x:Bind TotalCouponCount}" VerticalAlignment="Center" Padding="5" HorizontalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="9" Text="{x:Bind FreeCouponPriceDisplay}" VerticalAlignment="Center" Padding="5" HorizontalAlignment="Center" TextAlignment="Right"/>
                                            <TextBlock Grid.Column="10" Text="{x:Bind PaidCouponPriceDisplay}" VerticalAlignment="Center" Padding="5" HorizontalAlignment="Center" TextAlignment="Right" FontWeight="SemiBold"/>
                                            <TextBlock Grid.Column="11" Text="{x:Bind GrandTotalPriceDisplay}" VerticalAlignment="Center" Padding="5" HorizontalAlignment="Center" TextAlignment="Right" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}"/>
                                            

                                            <!-- เหตุผลยกเลิก -->
                                            <TextBlock Grid.Column="12" Text="{x:Bind CancellationReason}" VerticalAlignment="Center" TextWrapping="Wrap" Padding="5" HorizontalAlignment="Left" TextAlignment="Left" TextTrimming="CharacterEllipsis" MaxLines="3" Foreground="Red"/>

                                            <!-- vertical separators -->
                                            <Rectangle Grid.Column="0" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                            <Rectangle Grid.Column="1" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                            <Rectangle Grid.Column="2" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                            <Rectangle Grid.Column="3" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                            <Rectangle Grid.Column="4" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                            <Rectangle Grid.Column="5" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                            <Rectangle Grid.Column="6" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                            <Rectangle Grid.Column="7" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                            <Rectangle Grid.Column="8" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                            <Rectangle Grid.Column="9" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                            <Rectangle Grid.Column="10" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                            <Rectangle Grid.Column="11" HorizontalAlignment="Right" Width="1" Fill="#444" VerticalAlignment="Stretch" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- เพิ่มใน Grid หลัก ก่อน Border ของ Results Area -->
        <ProgressRing x:Name="LoadingRing" 
              Grid.Row="2"
              IsActive="False" 
              Width="60" Height="60"
              HorizontalAlignment="Center" 
              VerticalAlignment="Center"
              Visibility="Collapsed"/>
    </Grid>
</Page>
